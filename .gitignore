# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─────────────────────────────────────────────
# 虚拟环境
# ─────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ─────────────────────────────────────────────
# 模型权重（体积大，不入库）
# ─────────────────────────────────────────────
weights/*.h5
weights/*.pth
weights/*.jit
weights/*.pt
model_data/*.h5
model_data/*.weights

# ─────────────────────────────────────────────
# 数据集与输出
# ─────────────────────────────────────────────
data/
datasets/
output/
logs/

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ─────────────────────────────────────────────
# 系统文件
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─────────────────────────────────────────────
# TensorBoard 日志
# ─────────────────────────────────────────────
runs/
events.out.tfevents.*

# ─────────────────────────────────────────────
# 保留占位文件
# ─────────────────────────────────────────────
!weights/.gitkeep
!model_data/.gitkeep
!font/.gitkeep
!Video_Information/.gitkeep
